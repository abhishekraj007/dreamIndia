# Polar Configuration (Better-Auth Integration)
# Get these from https://polar.sh/dashboard

# Polar Access Token (required)
# Create from: Organization Settings > Access Tokens
POLAR_ACCESS_TOKEN=polar_at_xxxxx

# Polar Server Environment
# Use "sandbox" for testing, "production" for live
POLAR_SERVER=sandbox

# Polar Webhook Secret (required for webhooks)
# Get from: Organization Settings > Webhooks
POLAR_WEBHOOK_SECRET=polar_wh_xxxxx


# Site Configuration
SITE_URL=http://localhost:3004
NATIVE_APP_URL=quotes://

# Better-Auth Configuration
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# cockroachdreamindia
NEXT_PUBLIC_CONVEX_URL=https://expert-bird-512.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://expert-bird-512.convex.site
NEXT_PUBLIC_SITE_URL=http://localhost:3004
# Google Maps is proxied through Convex HTTP routes.
# Set the secret in Convex instead of exposing a public browser key:
#   npx convex env set GOOGLE_MAPS_KEY=your_google_maps_key
OPENAI_API_KEY=
