{
  "name": "cockroachdreamindia",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:admin": "turbo -F admin dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @convex-starter/backend dev",
    "dev:setup": "turbo -F @convex-starter/backend dev:setup",
    "convex:deploy": "pnpm -F @convex-starter/backend exec convex deploy --deployment expert-bird-512"
  },
  "devDependencies": {
    "@babel/traverse--for-generate-function-map": "npm:@babel/traverse@^7.29.0",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@10.14.0"
}
